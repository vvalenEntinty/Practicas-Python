from collections import defaultdict

opciones = ["1. Agregar un equipo", 
            "2. registrar un partido",
            "3. Mostrar tabla de posiciones",
            "4. eliminar un equipo",
            "5. Salir"]

equipos = {}
equipos = defaultdict(int)
print("¡Bienvenido a la Tabla de Posiciones!")
print("Selecciona una opción:")
for opcion in opciones:
    print(opcion)

opcion_S = int(input("Ingrese el número de la opción deseada: "))
while(opcion_S != 5):

    if opcion_S == 1:
        print("Opción 1: Agregar un equipo")
        equipo=(input("Ingrese el nombre del equipo: "))
        if (equipo in equipos):
            print(f"'{equipo}' ya esta registrado.")
        else:
            equipos[equipo] = 0
            print(f"Equipo '{equipo}' agregado a la tabla de posiciones.")

    if opcion_S == 2:
        print("Opción 2: Registrar un partido")
        equipo_local = input("Ingrese el nombre del equipo Local: ")
        equipo_visitante = input("Ingrese el nombre del equipo Visitante: ")
        marcador = input ("Ingrese el resultado del partido: ")
        aux = marcador.split('-')
        goles_local = int(aux[0])
        goles_visitante = int(aux[1])

        if (goles_local > goles_visitante):
            equipos[equipo_local] += 3
            equipos[equipo_visitante] +=0    
        elif (goles_local < goles_visitante):
            equipos[equipo_visitante] += 3
            equipos[equipo_local] += 0
        else:
            equipos[equipo_local] += 1
            equipos[equipo_visitante] += 1
            
    if opcion_S == 3:
        print(equipos)
    
    if (opcion_S == 4):
        equipo_eliminar = input ("Ingrese un equipo para Eliminarlo: ")
        del (equipos[equipo_eliminar])

    for opcion in opciones:
        print(opcion)
    opcion_S = int(input("Ingrese el número de la opción deseada: "))


